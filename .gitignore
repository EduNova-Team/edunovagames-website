# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# opening tree crawler cache (resumable, not committed)
scripts/.opening-tree-cache.json

# crawl run log (machine-specific output, regenerated each run)
scripts/.crawl.log

# generated opening tree (31MB, regenerate with scripts/fetch-opening-tree.mjs)
src/data/chessle-tree.json

# per-depth datasets (regenerate with scripts/build-all-depths.mjs)
src/data/chessle-openings-*.json
src/data/chessle-difficulties-*.json

# variant crawler caches (resumable, not committed)
scripts/.variant-*-cache.json

# raw variant crawl output (intermediate; build-variant-dataset.mjs finalizes it)
src/data/*-openings.raw.json

# variant crawl progress log (timestamped trackers, regenerated each run)
/logs

# generated crawl trackers (scripts/track-crawls.mjs)
/CRAWL-STATUS.md
/crawl-logs/
